{
  "name": "mindbrain",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev:api": "bun run --cwd apps/api dev",
    "dev:cli": "bun run --cwd apps/cli dev",
    "db:generate": "bun run --cwd apps/api db:generate",
    "db:push": "bun run --cwd apps/api db:push",
    "test": "bun test",
    "build:cli": "bun build apps/cli/src/index.ts --compile --outfile dist/mb"
  },
  "dependencies": {
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "pino-pretty": "^13.1.3"
  }
}
